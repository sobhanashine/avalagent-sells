# Supabase configuration. Create a free project at https://supabase.com
# then copy these values from Project Settings → API.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Used ONLY by `npm run seed` to provision the two operator accounts.
# Find it under Supabase → Project Settings → API → service_role (secret).
# ⚠️  Never expose this key publicly, in client code, or in version control.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key